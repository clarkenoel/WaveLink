// ============================================================
// Arduino Uno R4 WiFi — Access Point and UDP Listener Test
// Target: Arduino Uno R4 WiFi
// Purpose: Create a WiFi access point and receive UDP packets
//          from the Pico 2 WH gesture controller
// ============================================================
//
// This sketch does three things:
//   1. Creates a WiFi access point called "GestureNet"
//   2. Listens for incoming UDP packets on port 4210
//   3. Parses the 18-byte gesture packet and prints the
//      contents to the serial monitor
//
// Use this sketch to verify the wireless link works before
// adding actuator control code. Pair it with the Pico's
// wifi_test sketch or the final combined firmware.
//
// ============================================================

#include <WiFiS3.h>

// ============================================================
// NETWORK CONFIGURATION
// ============================================================
// These values must EXACTLY match what the Pico firmware uses.
// If even one character is different, the Pico cannot connect.

// The name of the WiFi network this Arduino creates.
// The Pico's firmware has this same string and will search
// for it when it boots.
const char* AP_SSID = "GestureNet";

// The password for the access point.
// Must be at least 8 characters for WPA2 security.
// The Pico's firmware has this same string.
const char* AP_PASSWORD = "hack2025";

// The UDP port to listen on.
// The Pico sends packets TO this port.
// Must match UDP_PORT in the Pico firmware.
const int UDP_PORT = 4210;

// ============================================================
// PACKET FORMAT
// ============================================================
// The Pico sends 18-byte packets with this structure:
//
// Byte 0:     Gesture index (0-254) or 255 for heartbeat
// Byte 1:     Confidence percentage (0-100)
// Bytes 2-17: Gesture name as null-terminated string
//
// The heartbeat packet has index 255, confidence 0,
// and name "heartbeat".

#define PACKET_SIZE     18
#define CMD_HEARTBEAT   255

// ============================================================
// GLOBAL OBJECTS
// ============================================================

// The UDP communication object for receiving packets.
// WiFiS3 library provides this class for the Uno R4 WiFi.
WiFiUDP udp;

// Buffer to hold one incoming packet
uint8_t packetBuffer[PACKET_SIZE];

// Track the WiFi access point status
int apStatus = WL_IDLE_STATUS;

// Track connected clients so we can report when the Pico
// connects or disconnects
int previousClientCount = 0;

// Heartbeat tracking
unsigned long lastHeartbeatReceived = 0;
bool heartbeatActive = false;

// ============================================================
// SETUP — RUNS ONCE ON BOOT
// ============================================================

void setup() {

    // Initialize serial communication for debug output.
    // Open the Arduino's serial monitor at 115200 baud
    // to see status messages and received packets.
    Serial.begin(115200);

    // Wait for serial monitor to open.
    // On the Uno R4, this wait is less critical than on the
    // Pico because the Uno's USB serial is handled by a
    // separate chip, but it ensures you see the startup
    // messages.
    while (!Serial) {
        delay(10);
    }
    delay(1000);

    Serial.println("========================================");
    Serial.println("Gesture Controller — Demo Station");
    Serial.println("WiFi Access Point + UDP Listener Test");
    Serial.println("========================================");
    Serial.println("");

    // --------------------------------------------------------
    // CHECK WIFI MODULE
    // --------------------------------------------------------
    // The Uno R4 WiFi has an ESP32-S3 module onboard that
    // handles all WiFi operations. We check that it is
    // present and responding before trying to create the
    // access point.

    if (WiFi.status() == WL_NO_MODULE) {
        Serial.println("ERROR: WiFi module not detected!");
        Serial.println("This board may not be the WiFi variant.");
        Serial.println("The Arduino Uno R4 comes in two versions:");
        Serial.println("  - Uno R4 Minima (no WiFi)");
        Serial.println("  - Uno R4 WiFi (has WiFi)");
        Serial.println("You need the WiFi version.");
        Serial.println("Halting.");
        while (true) {
            delay(1000);
        }
    }

    // Print the WiFi firmware version for debugging.
    // If this version is very old, some features may not
    // work correctly. The Arduino IDE board manager usually
    // keeps the firmware updated.
    String firmwareVersion = WiFi.firmwareVersion();
    Serial.print("WiFi module firmware: ");
    Serial.println(firmwareVersion);
    Serial.println("");

    // --------------------------------------------------------
    // CREATE THE ACCESS POINT
    // --------------------------------------------------------
    // WiFi.beginAP creates a new WiFi network that other
    // devices can connect to. The Arduino becomes the network
    // host, similar to a home router but much simpler.
    //
    // The Arduino assigns itself IP address 192.168.4.1
    // by default. Any device that connects gets an IP in
    // the 192.168.4.x range (the Pico will typically get
    // 192.168.4.2).
    //
    // This network is completely private and independent.
    // It does not connect to the internet. It does not use
    // the hackathon venue WiFi. It exists only between your
    // two devices.

    Serial.print("Creating access point: ");
    Serial.print(AP_SSID);
    Serial.println("...");

    apStatus = WiFi.beginAP(AP_SSID, AP_PASSWORD);

    if (apStatus != WL_AP_LISTENING) {
        Serial.println("ERROR: Failed to create access point!");
        Serial.println("Possible causes:");
        Serial.println("  - Password is less than 8 characters");
        Serial.println("  - WiFi module firmware needs updating");
        Serial.println("  - Another AP with the same SSID exists nearby");
        Serial.println("Halting.");
        while (true) {
            delay(1000);
        }
    }

    Serial.println("Access point created successfully!");
    Serial.println("");

    // Print network information
    Serial.println("Network Details:");
    Serial.print("  SSID:      ");
    Serial.println(AP_SSID);
    Serial.print("  Password:  ");
    Serial.println(AP_PASSWORD);
    Serial.print("  Arduino IP: ");
    Serial.println(WiFi.localIP());
    Serial.print("  Subnet:    ");
    Serial.println(WiFi.subnetMask());
    Serial.println("");

    // --------------------------------------------------------
    // START UDP LISTENER
    // --------------------------------------------------------
    // Open a UDP socket on the specified port.
    // The Arduino will now accept incoming UDP packets
    // sent to its IP address on this port.
    //
    // udp.begin() returns 1 on success, 0 on failure.

    int udpStarted = udp.begin(UDP_PORT);

    if (udpStarted) {
        Serial.print("UDP listener started on port ");
        Serial.println(UDP_PORT);
    } else {
        Serial.println("ERROR: Failed to start UDP listener!");
        Serial.println("Port may already be in use.");
        Serial.println("Halting.");
        while (true) {
            delay(1000);
        }
    }

    Serial.println("");
    Serial.println("========================================");
    Serial.println("Waiting for Pico to connect...");
    Serial.println("========================================");
    Serial.println("");
}

// ============================================================
// MAIN LOOP — RUNS CONTINUOUSLY FOREVER
// ============================================================

void loop() {

    // --------------------------------------------------------
    // MONITOR CLIENT CONNECTIONS
    // --------------------------------------------------------
    // Check how many devices are connected to our access point.
    // When the Pico connects, this count goes from 0 to 1.
    // When it disconnects, it goes back to 0.
    //
    // We track the previous count so we only print connection
    // and disconnection messages once, rather than flooding
    // the serial monitor every loop iteration.

    // The WiFiS3 library updates the AP status when clients
    // connect or disconnect. We check for changes.
    int currentStatus = WiFi.status();

    // Unfortunately the Uno R4 WiFi library does not have
    // a direct "number of connected clients" function in
    // all firmware versions. We use the AP status changes
    // to detect connections.
    //
    // WL_AP_LISTENING = AP is up, no clients connected
    // WL_AP_CONNECTED = AP is up, at least one client connected

    if (currentStatus == WL_AP_CONNECTED && previousClientCount == 0) {
        Serial.println(">>> CLIENT CONNECTED! <<<");
        Serial.println("The Pico has joined GestureNet.");
        Serial.println("Waiting for gesture packets...");
        Serial.println("");
        previousClientCount = 1;
    }

    if (currentStatus == WL_AP_LISTENING && previousClientCount == 1) {
        Serial.println(">>> CLIENT DISCONNECTED <<<");
        Serial.println("The Pico has left GestureNet.");
        Serial.println("Waiting for reconnection...");
        Serial.println("");
        previousClientCount = 0;
        heartbeatActive = false;
    }

    // --------------------------------------------------------
    // CHECK FOR INCOMING UDP PACKETS
    // --------------------------------------------------------
    // udp.parsePacket() checks if a new packet has arrived.
    // It returns the size of the packet in bytes, or 0 if
    // no packet is waiting.
    //
    // This is non-blocking — if no packet has arrived, it
    // returns 0 immediately and the loop continues. The
    // Arduino does not pause or wait for a packet.

    int packetSize = udp.parsePacket();

    // If no packet arrived, skip the rest and loop again
    if (packetSize == 0) {

        // --------------------------------------------------------
        // CHECK HEARTBEAT TIMEOUT
        // --------------------------------------------------------
        // If we were receiving heartbeats but haven't received
        // one in over 10 seconds, the wireless link may be down
        // even though the Pico is still technically connected
        // to the WiFi network.

        if (heartbeatActive) {
            unsigned long now = millis();
            if (now - lastHeartbeatReceived > 10000) {
                Serial.println("WARNING: Heartbeat timeout!");
                Serial.println("Pico may be frozen or out of range.");
                Serial.println("");
                heartbeatActive = false;
            }
        }

        return;
    }

    // --------------------------------------------------------
    // VALIDATE PACKET SIZE
    // --------------------------------------------------------
    // We expect exactly 18 bytes. If the packet is a different
    // size, something is wrong — either the Pico firmware is
    // sending the wrong format or we received a stray packet
    // from some other device.

    if (packetSize != PACKET_SIZE) {
        Serial.print("WARNING: Unexpected packet size: ");
        Serial.print(packetSize);
        Serial.print(" bytes (expected ");
        Serial.print(PACKET_SIZE);
        Serial.println(")");

        // Read and discard the malformed packet so it does
        // not clog the UDP buffer
        while (udp.available()) {
            udp.read();
        }
        return;
    }

    // --------------------------------------------------------
    // READ THE PACKET
    // --------------------------------------------------------
    // Read all 18 bytes into our buffer.
    // udp.read(buffer, size) reads up to 'size' bytes from
    // the packet into the buffer and returns how many bytes
    // were actually read.

    int bytesRead = udp.read(packetBuffer, PACKET_SIZE);

    if (bytesRead != PACKET_SIZE) {
        Serial.println("WARNING: Incomplete packet read");
        return;
    }

    // --------------------------------------------------------
    // PARSE THE PACKET
    // --------------------------------------------------------
    // Extract the three fields from the 18-byte packet:
    //   Byte 0:     gesture index
    //   Byte 1:     confidence percentage
    //   Bytes 2-17: gesture name string

    uint8_t gestureIndex  = packetBuffer[0];
    uint8_t confidence    = packetBuffer[1];

    // Extract the gesture name as a proper C string.
    // We copy it into a separate buffer and force null
    // termination to be safe, in case the Pico sent a
    // name that fills all 16 bytes without a terminator.
    char gestureName[16];
    memset(gestureName, 0, 16);
    memcpy(gestureName, &packetBuffer[2], 15);
    gestureName[15] = '\0';  // Force null termination

    // --------------------------------------------------------
    // HANDLE HEARTBEAT PACKETS
    // --------------------------------------------------------

    if (gestureIndex == CMD_HEARTBEAT) {
        lastHeartbeatReceived = millis();

        if (!heartbeatActive) {
            Serial.println("Heartbeat received — link is active");
            heartbeatActive = true;
        }

        // Print a subtle heartbeat indicator
        // In the final firmware this updates the LCD instead
        Serial.println("[♥] Heartbeat");
        return;
    }

    // --------------------------------------------------------
    // HANDLE GESTURE PACKETS
    // --------------------------------------------------------

    Serial.println("------------------------------------");
    Serial.println("GESTURE RECEIVED");
    Serial.print("  Name:       ");
    Serial.println(gestureName);
    Serial.print("  Index:      ");
    Serial.println(gestureIndex);
    Serial.print("  Confidence: ");
    Serial.print(confidence);
    Serial.println("%");
    Serial.print("  From IP:    ");
    Serial.println(udp.remoteIP());
    Serial.print("  From Port:  ");
    Serial.println(udp.remotePort());
    Serial.println("------------------------------------");
    Serial.println("");

    // --------------------------------------------------------
    // PLACEHOLDER FOR ACTUATOR CONTROL
    // --------------------------------------------------------
    // In the final demo_station firmware, this is where the
    // switch statement triggers actuators based on gestureIndex.
    // For this test sketch, we just print what WOULD happen.

    Serial.print("ACTION: ");
    switch (gestureIndex) {
        case 0:
            Serial.println("Would trigger action for class 0");
            break;
        case 1:
            Serial.println("Would trigger action for class 1");
            break;
        case 2:
            Serial.println("This is idle — should not arrive here");
            break;
        case 3:
            Serial.println("Would trigger action for class 3");
            break;
        case 4:
            Serial.println("Would trigger action for class 4");
            break;
        case 5:
            Serial.println("Would trigger action for class 5");
            break;
        case 6:
            Serial.println("Would trigger action for class 6");
            break;
        default:
            Serial.print("Unknown gesture index: ");
            Serial.println(gestureIndex);
            break;
    }
    Serial.println("");
}
