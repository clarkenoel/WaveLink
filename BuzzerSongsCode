// ============================================================
// Arduino Uno R4 WiFi — Gesture-Controlled Buzzer Music Player
// Receives UDP gesture packets from the Pico 2 WH and plays
// songs on a passive buzzer using tone().
//
// Wiring:
//   Buzzer (+) -> Pin 8
//   Buzzer (-) -> GND
//
// Gesture map:
//   Swipe Right -> next song
//   Swipe Left  -> previous song
//   Air Press   -> pause / play toggle
//
// Default state: no music playing (paused at song 0)
// ============================================================

#include <WiFiS3.h>

// ============================================================
// NETWORK CONFIGURATION
// ============================================================
const char* AP_SSID     = "WaveLinkNet";
const char* AP_PASSWORD = "Trailblazers1234";
const int   UDP_PORT    = 4210;

// ============================================================
// HARDWARE
// ============================================================
#define BUZZER_PIN  5

// ============================================================
// GESTURE INDICES — must match Pico firmware
// ============================================================
#define GESTURE_SWIPE_LEFT   0
#define GESTURE_SWIPE_RIGHT  1
#define GESTURE_AIR_PRESS    2
#define CMD_HEARTBEAT        255

// ============================================================
// PACKET FORMAT
// ============================================================
#define PACKET_SIZE 18

// ============================================================
// MUSIC — 5 songs stored as note/duration arrays
// Each song is a flat array: { note, duration, note, duration, ... }
// Duration is in milliseconds.
// Frequency 0 = rest.
// ============================================================

// --- Song 0: Happy Birthday ---
const int song0[] = {
    262,200, 262,200, 294,400, 262,400, 349,400, 330,800,
    262,200, 262,200, 294,400, 262,400, 392,400, 349,800,
    262,200, 262,200, 523,400, 440,400, 349,400, 330,400, 294,400,
    466,200, 466,200, 440,400, 349,400, 392,400, 349,800
};

// --- Song 1: Twinkle Twinkle ---
const int song1[] = {
    262,400, 262,400, 392,400, 392,400, 440,400, 440,400, 392,800,
    349,400, 349,400, 330,400, 330,400, 294,400, 294,400, 262,800,
    392,400, 392,400, 349,400, 349,400, 330,400, 330,400, 294,800,
    392,400, 392,400, 349,400, 349,400, 330,400, 330,400, 294,800,
    262,400, 262,400, 392,400, 392,400, 440,400, 440,400, 392,800,
    349,400, 349,400, 330,400, 330,400, 294,400, 294,400, 262,800
};

// --- Song 2: Ode to Joy ---
const int song2[] = {
    330,400, 330,400, 349,400, 392,400, 392,400, 349,400, 330,400, 294,400,
    262,400, 262,400, 294,400, 330,400, 330,600, 294,200, 294,800,
    330,400, 330,400, 349,400, 392,400, 392,400, 349,400, 330,400, 294,400,
    262,400, 262,400, 294,400, 330,400, 294,600, 262,200, 262,800
};

// --- Song 3: Jingle Bells (chorus) ---
const int song3[] = {
    330,400, 330,400, 330,800,
    330,400, 330,400, 330,800,
    330,400, 392,400, 262,400, 294,400, 330,1200,
    349,400, 349,400, 349,600, 349,200,
    349,400, 330,400, 330,400, 330,200, 330,200,
    330,400, 294,400, 294,400, 330,400, 294,800, 392,800
};

// --- Song 4: Mary Had a Little Lamb ---
const int song4[] = {
    330,400, 294,400, 262,400, 294,400, 330,400, 330,400, 330,800,
    294,400, 294,400, 294,800, 330,400, 392,400, 392,800,
    330,400, 294,400, 262,400, 294,400, 330,400, 330,400, 330,400, 330,400,
    294,400, 294,400, 330,400, 294,400, 262,800
};

// Pointers and lengths for each song
const int* songs[]    = { song0, song1, song2, song3, song4 };
const int  songLens[] = {
    sizeof(song0) / sizeof(song0[0]),
    sizeof(song1) / sizeof(song1[0]),
    sizeof(song2) / sizeof(song2[0]),
    sizeof(song3) / sizeof(song3[0]),
    sizeof(song4) / sizeof(song4[0])
};
const int  NUM_SONGS  = 5;

const char* songNames[] = {
    "Happy Birthday",
    "Twinkle Twinkle",
    "Ode to Joy",
    "Jingle Bells",
    "Mary Had a Little Lamb"
};

// ============================================================
// PLAYER STATE
// ============================================================
int  currentSong    = 0;   // Index into songs[]
int  noteIndex      = 0;   // Current position in the song array
bool isPlaying      = false;
unsigned long noteStartTime  = 0;
int           noteDuration   = 0;
bool          noteOn         = false;

// ============================================================
// UDP / NETWORK
// ============================================================
WiFiUDP  udp;
uint8_t  packetBuffer[PACKET_SIZE];
int      previousClientCount = 0;
unsigned long lastHeartbeat  = 0;
bool          heartbeatActive = false;

// ============================================================
// HELPERS
// ============================================================

void stopMusic() {
    noTone(BUZZER_PIN);
    noteOn    = false;
    noteIndex = 0;
    isPlaying = false;
}

void startSong(int index) {
    noTone(BUZZER_PIN);
    currentSong = index;
    noteIndex   = 0;
    noteOn      = false;
    isPlaying   = true;

    Serial.print("Now playing: ");
    Serial.println(songNames[currentSong]);
}

void nextSong() {
    int next = (currentSong + 1) % NUM_SONGS;
    startSong(next);
}

void prevSong() {
    int prev = (currentSong - 1 + NUM_SONGS) % NUM_SONGS;
    startSong(prev);
}

void togglePlayPause() {
    if (isPlaying) {
        noTone(BUZZER_PIN);
        isPlaying = false;
        noteOn    = false;
        Serial.println("Paused.");
    } else {
        isPlaying = true;
        Serial.print("Resuming: ");
        Serial.println(songNames[currentSong]);
    }
}

// ============================================================
// NON-BLOCKING MUSIC PLAYER
// ============================================================
// Called every loop(). Advances notes one at a time using
// millis() so it never blocks the UDP receiver.
//
// The song array is pairs: [frequency, duration, frequency, duration, ...]
// noteIndex always points to a frequency; noteIndex+1 is its duration.

void updatePlayer() {
    if (!isPlaying) return;

    unsigned long now = millis();

    if (noteOn) {
        // Check if current note has finished
        if (now - noteStartTime >= (unsigned long)noteDuration) {
            noTone(BUZZER_PIN);
            noteOn = false;
            noteIndex += 2;  // Advance to next note pair

            // Wrap around when song ends
            if (noteIndex >= songLens[currentSong]) {
                noteIndex = 0;
            }

            // Small gap between notes so they sound distinct
            delay(20);
        }

    } else {
        // Start the next note
        int freq     = songs[currentSong][noteIndex];
        noteDuration = songs[currentSong][noteIndex + 1];
        noteStartTime = millis();

        if (freq == 0) {
            // Rest — silence for this duration
            noTone(BUZZER_PIN);
        } else {
            tone(BUZZER_PIN, freq);
        }
        noteOn = true;
    }
}

// ============================================================
// SETUP
// ============================================================

void setup() {
    Serial.begin(115200);
    while (!Serial) delay(10);
    delay(500);

    pinMode(BUZZER_PIN, OUTPUT);
    noTone(BUZZER_PIN);

    Serial.println("========================================");
    Serial.println(" Gesture Music Player");
    Serial.println("========================================");
    Serial.println(" Default: paused at song 0");
    Serial.println(" Air Press  -> Play / Pause");
    Serial.println(" Swipe Right -> Next song");
    Serial.println(" Swipe Left  -> Previous song");
    Serial.println("========================================");

    // Check WiFi module
    if (WiFi.status() == WL_NO_MODULE) {
        Serial.println("ERROR: WiFi module not found. Halting.");
        while (true) delay(1000);
    }

    // Create access point
    Serial.print("Creating AP: ");
    Serial.println(AP_SSID);
    if (WiFi.beginAP(AP_SSID, AP_PASSWORD) != WL_AP_LISTENING) {
        Serial.println("ERROR: Could not create AP. Halting.");
        while (true) delay(1000);
    }

    Serial.print("Arduino IP: ");
    Serial.println(WiFi.localIP());

    // Start UDP
    if (!udp.begin(UDP_PORT)) {
        Serial.println("ERROR: UDP failed to start. Halting.");
        while (true) delay(1000);
    }

    Serial.print("Listening on UDP port ");
    Serial.println(UDP_PORT);
    Serial.println("Waiting for Pico to connect...");
}

// ============================================================
// MAIN LOOP
// ============================================================

void loop() {

    // --------------------------------------------------------
    // 1. Run the non-blocking music player
    // --------------------------------------------------------
    updatePlayer();

    // --------------------------------------------------------
    // 2. Monitor client connection
    // --------------------------------------------------------
    int status = WiFi.status();

    if (status == WL_AP_CONNECTED && previousClientCount == 0) {
        Serial.println(">>> Pico connected to GestureNet <<<");
        previousClientCount = 1;
    }
    if (status == WL_AP_LISTENING && previousClientCount == 1) {
        Serial.println(">>> Pico disconnected <<<");
        previousClientCount = 0;
        heartbeatActive = false;
    }

    // --------------------------------------------------------
    // 3. Heartbeat timeout check
    // --------------------------------------------------------
    if (heartbeatActive && millis() - lastHeartbeat > 10000) {
        Serial.println("WARNING: Heartbeat timeout — Pico may be frozen.");
        heartbeatActive = false;
    }

    // --------------------------------------------------------
    // 4. Check for incoming UDP packet
    // --------------------------------------------------------
    int packetSize = udp.parsePacket();
    if (packetSize == 0) return;

    if (packetSize != PACKET_SIZE) {
        while (udp.available()) udp.read();
        return;
    }

    int bytesRead = udp.read(packetBuffer, PACKET_SIZE);
    if (bytesRead != PACKET_SIZE) return;

    uint8_t gestureIndex = packetBuffer[0];

    // --------------------------------------------------------
    // 5. Handle heartbeat
    // --------------------------------------------------------
    if (gestureIndex == CMD_HEARTBEAT) {
        lastHeartbeat  = millis();
        heartbeatActive = true;
        return;
    }

    // --------------------------------------------------------
    // 6. Handle gestures
    // --------------------------------------------------------
    char gestureName[16];
    memset(gestureName, 0, 16);
    memcpy(gestureName, &packetBuffer[2], 15);
    gestureName[15] = '\0';

    Serial.print("Gesture: ");
    Serial.println(gestureName);

    switch (gestureIndex) {
        case GESTURE_SWIPE_RIGHT:
            nextSong();
            break;

        case GESTURE_SWIPE_LEFT:
            prevSong();
            break;

        case GESTURE_AIR_PRESS:
            // If stopped (default state), start playing from song 0
            // Otherwise toggle pause/play
            if (noteIndex == 0 && !isPlaying) {
                startSong(currentSong);
            } else {
                togglePlayPause();
            }
            break;

        default:
            Serial.print("Unknown gesture index: ");
            Serial.println(gestureIndex);
            break;
    }
}
