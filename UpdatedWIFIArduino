// ============================================================
// GESTURE NET — WiFi AP + UDP RECEIVER (ESP32 / ESP8266)
// ============================================================
// Pairs with: gesture_controller.ino on Raspberry Pi Pico 2 WH
//
// The Pico joins this board's access point and sends 18-byte UDP
// packets to 192.168.4.1:4210. This sketch must be uploaded to a
// board that supports WiFi.softAP() (ESP32, ESP8266, etc.).
// ============================================================

#if defined(ESP8266)
#include <ESP8266WiFi.h>
#include <WiFiUdp.h>
#elif defined(ESP32)
#include <WiFi.h>
#include <WiFiUdp.h>
#else
#error "Select board: ESP32 Dev Module or ESP8266 (this sketch uses WiFi.softAP)"
#endif

#include <string.h>

// Must match gesture_controller.ino / wifi_test.ino
static const char* AP_SSID     = "GestureNet";
static const char* AP_PASSWORD = "hack2025";
static const uint16_t UDP_PORT  = 4210;

static WiFiUDP udp;

void setup() {
  Serial.begin(115200);
  delay(300);

  Serial.println();
  Serial.println("========================================");
  Serial.println("GestureNet AP + UDP receiver");
  Serial.println("========================================");

  WiFi.mode(WIFI_AP);

#if defined(ESP8266)
  bool ok = WiFi.softAP(AP_SSID, AP_PASSWORD);
#else
  bool ok = WiFi.softAP(AP_SSID, AP_PASSWORD);
#endif

  Serial.print("softAP: ");
  Serial.println(ok ? "OK" : "FAILED — check SSID/password/channel");

  Serial.print("AP IP (Pico sends UDP here): ");
  Serial.println(WiFi.softAPIP());

  if (!udp.begin(UDP_PORT)) {
    Serial.println("FATAL: UDP.begin failed");
  } else {
    Serial.print("UDP listening on port ");
    Serial.println(UDP_PORT);
  }

  Serial.println("Waiting for Pico packets...");
  Serial.println("========================================");
}

void loop() {
  int n = udp.parsePacket();
  if (n <= 0) {
    return;
  }

  uint8_t buf[32];
  int len = udp.read(buf, sizeof(buf));
  if (len < 2) {
    return;
  }

  Serial.print("[UDP] from ");
  Serial.print(udp.remoteIP());
  Serial.print(" len=");
  Serial.print(len);
  Serial.print(" | idx=");
  Serial.print(buf[0]);
  Serial.print(" conf%=");
  Serial.print(buf[1]);

  if (buf[0] == 255) {
    Serial.print(" (heartbeat)");
  }

  if (len > 2) {
    char name[16];
    int nameLen = len - 2;
    if (nameLen > 15) {
      nameLen = 15;
    }
    memcpy(name, &buf[2], (size_t)nameLen);
    name[nameLen] = '\0';
    Serial.print(" name=");
    Serial.print(name);
  }
  Serial.println();
}
